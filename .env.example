# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== 大模型 API 配置 ====================
DASHSCOPE_API_KEY=sk-xxx
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# ==================== OpenAI 兼容 API 配置（本地嵌入模型） ====================
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIM=768

# ==================== PostgreSQL 数据库配置 ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fault_knowledge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# ==================== 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO

# ==================== 诊断参数 ====================
MAX_TRACE_DEPTH=3
KB_MIN_SCORE=5
MAX_SUPPORTING_LOGS=5
VECTOR_SEARCH_THRESHOLD=0.3
VECTOR_SEARCH_LIMIT=3
NEW_CASE_SIMILARITY_THRESHOLD=0.5
ENABLE_AUTO_LEARN=false

# ==================== 日志 API 配置 ====================
LOG_API_BASE_URL=http://localhost:8080
LOG_API_TIMEOUT=30
LOG_API_ENABLED=false
