# ==================== 环境变量配置说明 ====================
# 复制此文件为 config/.env 并根据实际环境修改
# 命令：cp config/.env.example config/.env

# ==================== LLM 大模型配置 ====================
# OpenAI 兼容模式 API Key
# 可用服务：OneAPI、NewAPI、SiliconCloud、DeepSeek 等
LLM_API_KEY=your-openai-compatible-api-key-here

# LLM API 基础 URL (OpenAI 兼容模式)
# 示例：
#   - OneAPI: http://localhost:3000/v1
#   - SiliconCloud: https://api.siliconflow.cn/v1
#   - DeepSeek: https://api.deepseek.com/v1
#   - 其他兼容服务：根据实际地址填写
LLM_BASE_URL=http://localhost:3000/v1

# LLM 模型名称
# 根据实际服务填写，例如：
#   - qwen-turbo, qwen-plus, qwen-max (阿里云)
#   - deepseek-chat, deepseek-coder (深度求索)
#   - glm-4, glm-3-turbo (智谱)
#   - moonshot-v1-8k (月之暗面)
LLM_MODEL=qwen-turbo

# LLM 推理温度 (0.0-1.0，越低输出越确定)
LLM_TEMPERATURE=0.1

# LLM 最大生成 token 数
LLM_MAX_TOKENS=1024


# ==================== EMBEDDING 嵌入模型配置 ====================
# Embedding API 基础 URL (可与 LLM 共用同一服务)
EMBEDDING_BASE_URL=http://localhost:3000/v1

# Embedding API Key (可与 LLM 共用)
EMBEDDING_API_KEY=your-openai-compatible-api-key-here

# Embedding 模型名称
# 根据实际服务填写，例如：
#   - text-embedding-v2, text-embedding-v3 (阿里云)
#   - bge-m3, bge-large-zh-v1.5 (智源)
#   - embedding-v2 (SiliconCloud)
EMBEDDING_MODEL=text-embedding-v2

# Embedding 向量维度
# 根据模型不同而不同：
#   - text-embedding-v2: 1536 维
#   - bge-m3: 1024 维
#   - bge-large-zh-v1.5: 1024 维
EMBEDDING_DIM=1536


# ==================== RERANK 重排序模型配置 ====================
# Rerank 模型名称
# 根据实际服务填写，例如：
#   - gte-rerank-v2 (阿里云)
#   - bge-reranker-v2-m3 (智源)
#   - rerank-v2 (SiliconCloud)
RERANK_MODEL=gte-rerank-v2

# Rerank 返回的顶部 K 个结果数
RERANK_TOP_K=5

# 是否启用 Rerank
RERANK_ENABLED=true

# Rerank 相似度阈值 (低于此值的案例被过滤)
RERANK_THRESHOLD=0.3


# ==================== PostgreSQL 数据库配置 ====================
# 数据库主机
POSTGRES_HOST=localhost

# 数据库端口
POSTGRES_PORT=5432

# 数据库名称
POSTGRES_DB=fault_knowledge

# 数据库用户名
POSTGRES_USER=postgres

# 数据库密码
POSTGRES_PASSWORD=postgres


# ==================== 向量检索配置 ====================
# 向量相似度阈值 (低于此值的案例不参与排序)
VECTOR_SEARCH_THRESHOLD=0.3

# 向量检索最大返回数量
VECTOR_SEARCH_LIMIT=10

# 新故障判定相似度阈值 (用于初筛)
NEW_CASE_SIMILARITY_THRESHOLD=0.5

# 是否启用自动学习 (自动将新故障加入知识库)
ENABLE_AUTO_LEARN=false


# ==================== 检索决策配置 ====================
# LLM 决策最大召回数量 (从精排结果中筛选的最大案例数)
LLM_DECISION_TOP_K=3


# ==================== 新故障判定配置 ====================
# 初筛向量相似度阈值 (高于此值进入 LLM 复查)
NEW_CASE_INITIAL_THRESHOLD=0.5

# 是否启用 LLM 语义复查 (两阶段判定)
NEW_CASE_LLM_REVIEW_ENABLED=true

# LLM 语义复查阈值 (LLM 输出的 confidence_score 高于此值判定为已有故障)
NEW_CASE_LLM_THRESHOLD=0.7


# ==================== 日志 API 配置 ====================
# 日志查询 API 基础 URL (微服务日志查询接口)
LOG_API_BASE_URL=http://localhost:8080

# 日志 API 请求超时时间 (秒)
LOG_API_TIMEOUT=30

# 是否启用日志 API
LOG_API_ENABLED=false


# ==================== 诊断参数配置 ====================
# 最大调用链追踪深度
MAX_TRACE_DEPTH=3

# 知识库最小匹配分数
KB_MIN_SCORE=5

# 最大支持日志数量 (用于根因分析)
MAX_SUPPORTING_LOGS=5


# ==================== 服务配置 ====================
# 服务监听地址
SERVER_HOST=0.0.0.0

# 服务监听端口
SERVER_PORT=8000

# 日志级别
# 可选：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
