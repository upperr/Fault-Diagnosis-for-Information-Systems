# 环境变量配置示例
# 复制此文件为 .env 并根据实际情况修改

# ==================== LLM 大模型配置 ====================
# 大模型 API Key（用于根因分析、日志关联、检索决策等）
LLM_API_KEY=sk-xxx

# 大模型 API 基础 URL（OpenAI 兼容格式）
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 大模型名称
LLM_MODEL=qwen-turbo

# 大模型推理参数
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1024


# ==================== EMBEDDING 嵌入模型配置 ====================
# 嵌入模型 API 基础 URL（OpenAI 兼容格式，如 Ollama: http://localhost:11434/v1）
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 嵌入模型 API Key
EMBEDDING_API_KEY=sk-xxx

# 嵌入模型名称
EMBEDDING_MODEL=text-embedding-v2

# 向量维度（根据模型调整：text-embedding-v2=1536, mxbai-embed-large=1024, nomic-embed-text=768）
EMBEDDING_DIM=1536


# ==================== RERANK 重排序模型配置 ====================
# Rerank 模型名称（阿里云 DashScope: qwen3-rerank, gte-rerank-v2 等）
RERANK_MODEL=qwen3-rerank

# Rerank 精排后返回数量
RERANK_TOP_K=3

# 是否启用 Rerank 精排
RERANK_ENABLED=true

# Rerank 相关性阈值（低于此值视为不相关）
RERANK_THRESHOLD=0.5


# ==================== PostgreSQL 数据库配置 ====================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fault_knowledge
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres


# ==================== 向量检索配置 ====================
# 向量检索相似度阈值（粗排）
VECTOR_SEARCH_THRESHOLD=0.3

# 向量检索返回数量（粗排召回数量）
VECTOR_SEARCH_LIMIT=10

# 新故障判定阈值（低于此值判定为新故障）
NEW_CASE_SIMILARITY_THRESHOLD=0.5

# 是否启用自动学习（新故障自动入库）
ENABLE_AUTO_LEARN=false


# ==================== 日志 API 配置 ====================
# 日志查询 API 基础 URL（默认使用本地 mock 服务地址）
LOG_API_BASE_URL=http://localhost:8080

# API 请求超时时间（秒）
LOG_API_TIMEOUT=30

# 是否启用 API 模式（False 时使用本地 mock 数据降级）
LOG_API_ENABLED=false


# ==================== 诊断参数配置 ====================
# 全链路追踪最大深度
MAX_TRACE_DEPTH=3

# 知识库匹配最低分数阈值
KB_MIN_SCORE=5

# 报告最大支撑日志条数
MAX_SUPPORTING_LOGS=5


# ==================== 服务配置 ====================
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
